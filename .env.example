# ImageKit Configuration (Beta 3.2)
# Uzyskaj te klucze na https://imagekit.io/dashboard/developer/api-keys
VITE_IMAGEKIT_PUBLIC_KEY=your_public_key_here
VITE_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id/
VITE_IMAGEKIT_AUTH_ENDPOINT=http://localhost:3000/auth # Opcjonalnie, do bezpiecznego uploadu

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
